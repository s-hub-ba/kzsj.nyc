rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "ivanadurovic94@gmail.com" ||
        request.auth.token.email == "amraisakovic.fig@gmail.com"
      );
    }

    match /classes/{docId} {
      allow read: if resource.data.active == true;
      allow write: if isAdmin();
    }

    match /terms/{docId} {
      allow read: if resource.data.active == true;
      allow write: if isAdmin();
    }

    match /blogPosts/{docId} {
      allow read: if resource.data.published == true;
      allow write: if isAdmin();
    }

    match /bookings/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /newsletterSubscribers/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /jobApplications/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /invoices/{docId} {
      allow read, write: if isAdmin();
    }

    match /invoiceCounters/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
